# -------------------------------------------------------
# node-bot environment variables
# Copy this file to .env and fill in your values.
# NEVER commit a .env file with real keys to Git.
# -------------------------------------------------------

# --- OpenAI / proxy API (set these to use the proxy instead of local llama) ---
# Your API key (or your co-intern's key).
# To swap keys: just change OPENAI_API_KEY and restart the server.
OPENAI_API_KEY=sk-YOUR_KEY_HERE

# The base URL of the proxy server.
# Default is already set to your co-intern's server: https://new.aicode.us.com
# You can override it here if you use a different proxy or the real OpenAI API:
OPENAI_BASE_URL=https://new.aicode.us.com

# The model name to use on the proxy.
OPENAI_MODEL=codex-gpt-5.5

# --- Whisper (local STT) ---
WHISPER_BIN=C:\ManaAI\Mana\tools\whisper\Release\whisper-cli.exe
WHISPER_MODEL=C:\ManaAI\Mana\tools\whisper\models\ggml-tiny.en.bin

# --- Local llama (fallback if OPENAI_API_KEY is not set) ---
# LLAMA_BIN=C:\ManaAI\Mana\tools\llama\llama-b9436-bin-win-cuda-12.4-x64\llama.exe
# LLAMA_MODEL=C:\ManaAI\Mana\tools\llama\gguf-models\llama-2-7b-chat-q4_0.gguf

# --- TTS provider ---
# TTS_PROVIDER=chatterbox
