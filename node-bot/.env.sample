# -------------------------------------------------------
# node-bot environment variables
# Copy this file to .env and fill in your values.
# NEVER commit a .env file with real keys to Git.
# -------------------------------------------------------

# --- AI replies ---
# Mana is local-first. OPENAI_API_KEY is ignored unless MANA_ALLOW_REMOTE_AI=1.
# Leave MANA_ALLOW_REMOTE_AI unset or set it to 0 for strictly local AI replies.
MANA_ALLOW_REMOTE_AI=0

# --- Whisper (local STT) ---
WHISPER_BIN=C:\ManaAI\Mana\tools\whisper\Release\whisper-cli.exe
WHISPER_MODEL=C:\ManaAI\Mana\tools\whisper\models\ggml-tiny.en.bin

# --- Local llama ---
# LLAMA_BIN=C:\ManaAI\Mana\tools\llama\llama-b9436-bin-win-cuda-12.4-x64\llama.exe
# LLAMA_MODEL=C:\ManaAI\Mana\tools\llama\gguf-models\llama-2-7b-chat-q4_0.gguf

# --- Optional remote AI escape hatch ---
# Only set these if you intentionally want paid/proxy chat replies.
# MANA_ALLOW_REMOTE_AI=1
# OPENAI_API_KEY=sk-YOUR_KEY_HERE
# OPENAI_BASE_URL=https://new.aicode.us.com
# OPENAI_MODEL=codex-gpt-5.5

# --- TTS provider ---
# TTS_PROVIDER=chatterbox

# --- Mobile PWA companion ---
# Generate MOBILE_PASSCODE_HASH from node-bot without putting the passcode in shell history:
# $p = Read-Host -AsSecureString "Mana mobile passcode"; $b = [Runtime.InteropServices.Marshal]::SecureStringToBSTR($p); try { [Runtime.InteropServices.Marshal]::PtrToStringBSTR($b) | node -e "const fs = require('fs'); const { hashPasscode } = require('./mobile-auth'); const pass = fs.readFileSync(0, 'utf8').replace(/\r?\n$/, ''); console.log(hashPasscode(pass));" } finally { [Runtime.InteropServices.Marshal]::ZeroFreeBSTR($b) }
MOBILE_PASSCODE_HASH=pbkdf2_sha256$120000$REPLACE_SALT$REPLACE_HASH

# Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MOBILE_SESSION_SECRET=replace-with-random-hex
MOBILE_SESSION_TTL_MS=43200000
MOBILE_MEMORY_DIR=C:\ManaAI\Mana\node-bot\data
