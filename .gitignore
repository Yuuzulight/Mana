# Ignore tool binaries and large model files
/tools/llama/
/ManaAIManatext-generation-webui/
/text-generation-webui/

# Bundled Node runtime staged for a standalone desktop-client installer
# build (see BUILD_DESKTOP.md); never a source file, always a local copy
# of an official Node.js binary.
/node-bin/

# electron-builder output (installer .exe, unpacked app, blockmap)
desktop-client/dist/

# Ignore virtualenvs and node modules
**/venv/
**/node_modules/
win-bot/venv/

# Ignore temp and logs
node-bot/tmp/
*.log
*.zip
*.exe
nul

# Ignore model download artifacts (optionally keep model manifests)
tools/whisper/Release/
tools/ffmpeg/
tts-service/kokoro/

# OS files
Thumbs.db
.DS_Store

# Env files with secrets (never commit these)
.env
*.env
!*.env.sample

# Local implementation worktrees
.worktrees/

# Local Mana runtime data: memory store, sessions, auth keys, accounts
# (includes node-bot/data/auth/SETUP.txt with admin key and accounts.json with user keys)
node-bot/data/

# Job application tracker + answer knowledge base -- personal job-search data
plugins/job-applications/data/

# Vector store (local index/embeddings)
/tools/vector_store/
tools/vector_store/

# Large audio and model assets
tools/whisper/models/
mana-younger-sister-voice-test.wav
tools/whisper/test.wav
tts-language-tests*/
tools/whisper/models/*.bin

# Live2D runtime (proprietary, fetched by npm run fetch-live2d-core) and personal avatar model
windows-launcher/assets/live2d/
windows-launcher/avatar/model/
desktop-client/assets/live2d/
desktop-client/avatar/model/

# Mana's sprite artwork (all rights reserved, see LICENSE-ARTWORK) is not
# distributed with the public repo; the desktop app degrades gracefully
# (sprite <img>/background-image calls silently no-op) if it's absent.
/sprites/

# Personal voice references (never commit someone's voice)
tts-service/references/
tts-service/voice-auditions/
tts-service/*.wav
tts-service/*.mp3
tts-service/*-transcript*.txt

# Python bytecode cache (build artifact, not source)
__pycache__/
*.pyc

# Local SearXNG install (fetched by tools/setup-searxng.ps1; large venv).
# mana-searxng-settings.yml is tracked outside this tree so setup survives a
# fresh clone; setup-searxng.ps1 copies it in as tools/searxng/mana-settings.yml.
tools/searxng/

# GPT-SoVITS trial voice provider (huge self-contained package, ~20GB extracted).
# See docs/gpt_sovits_setup.md for setup; reference clips live in tts-service/references/.
tools/gpt-sovits/

# Obsidian plugin build output (source is main.ts; main.js is generated by esbuild)
obsidian-plugin/main.js
obsidian-plugin/main.js.map
